{
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "editor.rulers": [
    120
  ],
  "[python]": {
    "editor.tabSize": 4
  },
  "cpplint.lineLength": 120,
  "cpplint.filters": [
    "-build/include_subdir",
    "-runtime/references"
  ],
  "C_Cpp.autoAddFileAssociations": false,
  "C_Cpp.files.exclude": {
    "**/build/**": true,
    "**/build_*/**": true,
    "**/cmake/external/**": true,
    "**/node_modules/**": true,
    "**/.git/**": true
  },
  "search.exclude": {
    "**/build/**": true,
    "**/build_*/**": true,
    "**/cmake/external/**": true,
    "**/node_modules/**": true,
    "**/.git/**": true
  },
  "C_Cpp_Runner.msvcBatchPath": ""
}