{
  "build_osx_archs": {
    "iphoneos": [
      "arm64"
    ],
    "iphonesimulator": [
      "arm64",
      "x86_64"
    ]
  },
  "build_params": {
    "base": [
      "--parallel",
      "--build_apple_framework",
      "--skip_tests",
      "--minimal_build",
      "--disable_ml_ops",
      "--disable_exceptions",
      "--enable_reduced_operator_type_support",
      "--no_kleidiai",
      "--cmake_extra_defines=onnxruntime_BUILD_UNIT_TESTS=OFF"
    ],
    "iphoneos": [
      "--ios",
      "--use_xcode",
      "--apple_deploy_target=15.0"
    ],
    "iphonesimulator": [
      "--ios",
      "--use_xcode",
      "--apple_deploy_target=15.0"
    ]
  }
}
