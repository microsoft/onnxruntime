# Resolved (machine-specific) variant configs for the non-portable package.
# Generated by nonportable_package/resolve.py; commit only *.template.json.
nonportable_package/**/ort_info.json

# Build-time scratch and compiled sample binaries.
_staging/
cpp/*.exe
cpp/*.pdb
cpp/*.obj

# This sample intentionally ships its model artifacts so the packages work
# straight from a checkout. The repo-root .gitignore excludes *.onnx and *.bin;
# re-include them (and .data) for this sample tree only.
!**/*.onnx
!**/*.bin
!**/*.data