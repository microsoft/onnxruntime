          { "data": [4], "dims": [], "type": "int64" },
          { "data": [-2], "dims": [], "type": "int64" }
        ],
        "outputs": [{ "data": [2, 1, -2, -3, 0, -1, 4, 3], "dims": [1, 4, 2], "type": "float32" }]
      }
