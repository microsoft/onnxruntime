        "outputs": [{ "data": [1, 0, 2, -1, 0, 0, -1, 2], "dims": [1, 4, 2], "type": "float32" }]
      }
    ]
  },
  {
    "name": "DFT one-sided forward / RFFT (opset 17)",
    "operator": "DFT",
    "attributes": [
      { "name": "axis", "data": 1, "type": "int" },
      { "name": "onesided", "data": 1, "type": "int" }
