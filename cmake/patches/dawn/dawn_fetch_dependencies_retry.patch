+def run_with_retry(cmd_fn, description, retries=3):
+    """
+    Run a git command (returned by cmd_fn as a CompletedProcess), retrying on
+    failure and raising a RuntimeError if it never succeeds.
+
+    The upstream script issues all git commands with capture_output=True and
+    never inspects the return code. When a network fetch/clone/checkout fails
+    (e.g. a transient git server error) the dependency directory is left empty
+    or partially populated. That later surfaces as confusing build failures
+    such as a missing CMakeLists.txt for vulkan-headers / vulkan-utility-
+    libraries or an empty 'jinja2' package that has no BaseLoader attribute.
+    Failing loudly (after retries) makes such fetch failures obvious and
+    recoverable.
+    """
+    last = None
+    for attempt in range(1, retries + 1):
+        last = cmd_fn()
+        if last.returncode == 0:
+            return last
+        stderr = last.stderr.decode(errors='replace') if last.stderr else ''
+        log(f"WARNING: {description} failed "
+            f"(attempt {attempt}/{retries}, exit code {last.returncode}):\n"
+            f"{stderr}")
+    stderr = last.stderr.decode(errors='replace') if last.stderr else ''
+    raise RuntimeError(
+        f"{description} failed after {retries} attempts "
+        f"(exit code {last.returncode}):\n{stderr}")
+
+
